{
    "color": {
        "neutral": {
            "0": {
                "$value": "#ffffff",
                "$type": "color",
                "$description": "Pure white — used for link hover backgrounds and section backgrounds"
            },
            "100": {
                "$value": "#f9f4ef",
                "$type": "color",
                "$description": "Warm off-white — page/body background"
            },
            "200": {
                "$value": "#b3d4fd",
                "$type": "color",
                "$description": "Light blue — text selection highlight"
            },
            "400": {
                "$value": "#a4a9b0",
                "$type": "color",
                "$description": "Muted gray — placeholder text"
            },
            "500": {
                "$value": "#999999",
                "$type": "color",
                "$description": "Medium gray"
            },
            "600": {
                "$value": "#808080",
                "$type": "color",
                "$description": "Gray — used on <hr> dividers"
            },
            "700": {
                "$value": "#666666",
                "$type": "color",
                "$description": "Dark gray — secondary text"
            },
            "800": {
                "$value": "#444444",
                "$type": "color",
                "$description": "Near-black — primary body text color"
            },
            "1000": {
                "$value": "#000000",
                "$type": "color",
                "$description": "True black"
            }
        },
        "blue": {
            "500": {
                "$value": "#004984",
                "$type": "color",
                "$description": "Primary brand blue — used for links and CTA button backgrounds"
            },
            "500-alpha-90": {
                "$value": "rgba(0, 73, 132, 0.9)",
                "$type": "color",
                "$description": "Brand blue at 90% opacity — used for CTA button background"
            }
        },
        "white": {
            "alpha-50": {
                "$value": "rgba(255, 255, 255, 0.5)",
                "$type": "color",
                "$description": "Semi-transparent white — used for the Values section block background"
            }
        }
    },
    "fontFamily": {
        "serif": {
            "$value": "\"Source Serif\"",
            "$type": "fontFamily",
            "$description": "Primary typeface — used for all body text, headings, navigation, and links"
        }
    },
    "fontWeight": {
        "extralight": {
            "$value": 200,
            "$type": "fontWeight",
            "$description": "Source Serif ExtraLight"
        },
        "light": {
            "$value": 300,
            "$type": "fontWeight",
            "$description": "Source Serif Light"
        },
        "regular": {
            "$value": 400,
            "$type": "fontWeight",
            "$description": "Source Serif Regular — default weight for body text and headings"
        },
        "medium": {
            "$value": 500,
            "$type": "fontWeight",
            "$description": "Source Serif Medium"
        },
        "semibold": {
            "$value": 600,
            "$type": "fontWeight",
            "$description": "Source Serif SemiBold"
        },
        "black": {
            "$value": 900,
            "$type": "fontWeight",
            "$description": "Source Serif Black"
        }
    },
    "fontSize": {
        "base": {
            "$value": "18px",
            "$type": "fontSize",
            "$description": "Root/html base font size — 18px static, before fluid scaling"
        },
        "body-fluid": {
            "$value": "calc(125% + 0.8vw)",
            "$type": "fontSize",
            "$description": "Fluid body font size applied to <body> — scales with viewport width (125% of 18px base + 0.8vw)"
        },
        "xs": {
            "$value": "0.6em",
            "$type": "fontSize",
            "$description": "Extra small text — used for .small utility class"
        },
        "sm": {
            "$value": "0.7em",
            "$type": "fontSize",
            "$description": "Small text — used in form helper text"
        },
        "sm-2": {
            "$value": "0.8em",
            "$type": "fontSize",
            "$description": "Small-medium — used in supplemental content"
        },
        "sm-3": {
            "$value": "0.85em",
            "$type": "fontSize",
            "$description": "Near-base small — used in Values/highlighted section (font-size: 0.85em)"
        },
        "sm-4": {
            "$value": "0.88em",
            "$type": "fontSize",
            "$description": "Near-base — used for previous/next entry navigation"
        },
        "md": {
            "$value": "0.9em",
            "$type": "fontSize",
            "$description": "Body paragraph and list item size (relative to body fluid size)"
        },
        "md-2": {
            "$value": "1em",
            "$type": "fontSize",
            "$description": "Base relative size — 1em"
        },
        "lg": {
            "$value": "1.1em",
            "$type": "fontSize",
            "$description": "Slightly larger — used for h3 and entry h2"
        },
        "xl": {
            "$value": "1.156em",
            "$type": "fontSize",
            "$description": "Used for next/previous entry titles"
        },
        "2xl": {
            "$value": "1.25em",
            "$type": "fontSize",
            "$description": "Aside headings (h1 inside aside)"
        },
        "3xl": {
            "$value": "1.3em",
            "$type": "fontSize",
            "$description": "h2 size"
        },
        "4xl": {
            "$value": "1.5em",
            "$type": "fontSize",
            "$description": "Large heading / listing title"
        },
        "5xl": {
            "$value": "1.6em",
            "$type": "fontSize",
            "$description": "Large h1 for special pages"
        },
        "6xl": {
            "$value": "2.5em",
            "$type": "fontSize",
            "$description": "Hero headline on home page"
        },
        "nav": {
            "$value": "16px",
            "$type": "fontSize",
            "$description": "Navigation link font size — fixed at 16px, not fluid"
        }
    },
    "fontStyle": {
        "normal": {
            "$value": "normal",
            "$type": "fontStyle"
        },
        "italic": {
            "$value": "italic",
            "$type": "fontStyle",
            "$description": "Used for h5 headings and emphasis text"
        }
    },
    "lineHeight": {
        "tight": {
            "$value": 1.2,
            "$type": "lineHeight",
            "$description": "Tight line height — used for headings and compact text"
        },
        "base": {
            "$value": 1.45,
            "$type": "lineHeight",
            "$description": "Base body line height"
        }
    }
}